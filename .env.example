# Secrets
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=yourstorage;AccountKey=your-key;EndpointSuffix=core.windows.net"
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://your-resource.unitedstates.communication.azure.com/;accesskey=your-access-key"
AZURE_SERVICE_BUS_CONNECTION_STRING="Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key"
AUTH_SECRET="a-long-random-secret"
ADMIN_PERMISSION_TOKEN="a-separate-long-random-admin-bootstrap-token"
OPENAI_API_KEY="sk-..."

# App variables
AZURE_BLOB_CONTAINER="cv-files"
AZURE_TABLES_TABLE_NAME="cvcollector"
AZURE_EMAIL_SENDER_ADDRESS="DoNotReply@your-verified-domain.azurecomm.net"
AZURE_SERVICE_BUS_OTP_QUEUE_NAME="otp-email"
APP_BASE_URL="http://localhost:3000"
ATS_OPENAI_MODEL="gpt-4o-mini"
ADMIN_PERMISSION_TOKEN_EXPIRES_AT="2026-12-31T23:59:59.000Z"

# Deployment variables
AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000000"
AZURE_STORAGE_ACCOUNT_NAME="yourstorage"
AZURE_COMMUNICATION_SERVICE_NAME="acs-your-service"
AZURE_SERVICE_BUS_NAMESPACE_NAME="sb-your-service"
AZURE_RESOURCE_GROUP="your-resource-group"
AZURE_CONTAINER_APP_NAME="ca-cvcollector"
AZURE_CONTAINERAPPS_ENVIRONMENT="cae-cvcollector"
AZURE_CONTAINER_REGISTRY_NAME="yourregistry"
AZURE_CONTAINER_REGISTRY_LOGIN_SERVER="yourregistry.azurecr.io"
AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
